cloudMesh: {
  type: "NoiseMesh"
  color: "ffffff"
  // 可留空表示无云层
}
hidden: false
alwaysUnlocked: true

// 技术树（可选）
// 如果该星球有自己的科技树，可在此指定根节点
//techTree: "entropy-iron"

// 解锁后自动解锁的内容（内容名数组）
//unlockedOnLand: [
//  "item",
//  "block"
//]
