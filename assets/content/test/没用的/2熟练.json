	//如果为false 则没有永远存在的效果
	"reactive":false,
	//如果为true，则此效果将仅与其他效果反应无法应用
	"color":"444444",
	//状态颜色
	"disarm":false,
	//是否解除武装
	"effect": {
	    "type":"waveEffect"
	    "lifetime":60
	    "sizeFrom":0
	    "sizeTo":5
	    "colorFrom":"444444"
	    "colorTo":"444444"
	},
	"effectChance":1,
	//效果数量（数值越大,效果越多越密集）
