	//是否显示
	"color":"8000ff"
	//状态颜色
	"effect": {
	    "type":"ParticleEffect"
	    "particles":2
	    "length":0
	    "sizeFrom":2
	    "sizeTo":0
	    "colorFrom":"#8000ff"
	    "colorTo":"#7181ff"
	}
	//效果
	"effectChance":1
	//效果数量（数值越大,效果越多越密集）
